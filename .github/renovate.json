{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "regexManagers": [
    {
      "fileMatch": ["^internal/web/static/.*\\.html$"],
      "matchStrings": [
        "cdn\\.jsdelivr\\.net/npm/(?<depName>[^@/]+)@(?<currentValue>[^/]+)/"
      ],
      "datasourceTemplate": "npm"
    }
  ],
  "packageRules": [
    {
      "matchManagers": ["dockerfile", "github-actions", "gomod", "regex"],
      "matchUpdateTypes": ["minor", "patch", "digest"],
      "automerge": true,
      "automergeType": "pr"
    },
    {
      "matchManagers": ["dockerfile", "github-actions", "gomod", "regex"],
      "matchUpdateTypes": ["major"],
      "automerge": false,
      "dependencyDashboardApproval": false,
      "labels": ["major-update"]
    }
  ]
}
